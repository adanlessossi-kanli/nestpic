# Application environment
NODE_ENV=development

# Object store (S3 / OpenStack Swift)
OBJECT_STORE_ENDPOINT=http://localhost:8080
OBJECT_STORE_ACCESS_KEY=your-access-key
OBJECT_STORE_SECRET_KEY=your-secret-key
OBJECT_STORE_BUCKET=nestpic

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nestpic

# Session
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# CDN (CloudFront)
CDN_BASE_URL=https://your-distribution.cloudfront.net
CDN_KEY_PAIR_ID=your-cloudfront-key-pair-id
CDN_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nyour-private-key-here\n-----END RSA PRIVATE KEY-----

# AWS Secrets Manager (production only)
SECRETS_MANAGER_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:nestpic/prod-AbCdEf
